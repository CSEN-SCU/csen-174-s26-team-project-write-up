PORT=8787
COACH_LLM=auto
GROQ_API_KEY=ask Chris for the key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=unset/empty
OPENAI_MODEL=gpt-4o-mini
# TF–IDF retrieval: chunks merged from full draft, tail window, and spelling-augmented query
RAG_TOP_K=8

# Opt-in LLM I/O logging to stderr (JSON lines prefixed with [coach-llm]). Default: off.
# COACH_LOG_LLM=1
# Preview length per message field (default 400, max 8000). Omit middle of long strings unless COACH_LOG_LLM_FULL=1.
# COACH_LOG_LLM_PREVIEW=400
# COACH_LOG_LLM_FULL=1
