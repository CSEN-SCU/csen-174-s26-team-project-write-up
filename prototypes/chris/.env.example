# Template only — never loaded by the app. Copy to a real .env (gitignored) and put secrets there.
# Copy to: prototypes/chris/.env  (same folder as this file), OR prototypes/chris/server/.env
# The server loads ONLY those .env files — not this .env.example file.

PORT=8787

# LLM for coaching (same RAG context to both). Set at least one of GROQ_API_KEY or OPENAI_API_KEY.
# COACH_LLM=auto|groq|openai — auto prefers Groq when GROQ_API_KEY is set, then OpenAI as fallback.
COACH_LLM=auto

# Groq (OpenAI-compatible Chat Completions API)
GROQ_API_KEY=
# Default in code is llama-3.3-70b-versatile (English / coaching-friendly on Groq).
# GROQ_MODEL=llama-3.3-70b-versatile
# Alternatives: openai/gpt-oss-120b, openai/gpt-oss-20b, llama-3.1-8b-instant (faster, lighter), qwen/qwen3-32b (preview)
# GROQ_API_BASE=https://api.groq.com/openai/v1

# OpenAI (optional fallback or set COACH_LLM=openai to prefer)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
