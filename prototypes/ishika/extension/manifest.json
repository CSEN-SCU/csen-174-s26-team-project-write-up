{
  "manifest_version": 3,
  "name": "Write Up",
  "version": "0.1.0",
  "description": "Learning-first writing feedback in Chrome’s side panel. Requires the local Write Up server on port 5050.",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": [
    "http://127.0.0.1:5050/*",
    "http://localhost:5050/*",
    "https://docs.google.com/*"
  ],
  "action": {
    "default_title": "Open Write Up side panel"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:5050/*", "http://localhost:5050/*"],
      "js": ["content-landing.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["content-docs-live.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
