{
  "manifest_version": 3,
  "name": "Write Up — Catherine prototype",
  "version": "0.1.0",
  "description": "Mentor-style vocabulary diagnostics: crutch-word highlights, synonyms, definitions, and rewrites by writing level.",
  "action": {
    "default_title": "Write Up",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "analyze-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Analyze selected text with Write Up"
    }
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardRead",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:3847/*",
    "http://127.0.0.1:3847/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
