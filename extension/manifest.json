{
  "manifest_version": 3,
  "name": "Write Up",
  "version": "0.1.0",
  "description": "Learning-first writing feedback in Chrome side panel.",
  "minimum_chrome_version": "116",
  "permissions": ["sidePanel", "storage"],
  "host_permissions": [
    "http://127.0.0.1:5050/*",
    "http://localhost:5050/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "http://127.0.0.1:5173/*",
    "http://localhost:5173/*",
    "https://docs.google.com/*"
  ],
  "action": { "default_title": "Open Write Up side panel" },
  "background": { "service_worker": "src/background.js" },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:5173/*", "http://localhost:5173/*"],
      "js": ["src/content/landing.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["src/content/docs.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": { "default_path": "src/sidepanel/sidepanel.html" }
}
